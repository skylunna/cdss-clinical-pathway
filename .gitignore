# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/

# ===== Virtual Environment =====
.venv/
venv/
env/
ENV/

# ===== uv =====
# uv.lock 是否提交有争议:
# - 应用项目(我们这种)应该提交,保证环境一致
# - 库项目通常不提交
# 我们提交它。
# uv.lock  ← 不忽略

# ===== Environment Variables (敏感!) =====
.env
.env.local
.env.*.local

