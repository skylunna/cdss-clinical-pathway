# ============================================
# LLM Provider Configuration
# ============================================
# 至少配置一个LLM提供方
# 国内推荐 DeepSeek(便宜)或通义千问;国外用 OpenAI
# 后续我们会先用 DeepSeek 跑通

# DeepSeek (推荐先用这个,价格便宜,接口兼容OpenAI)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (可选)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 通义千问 (可选)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# Database Configuration
# ============================================
# 我们用 PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://cdss_user:cdss_pass@localhost:5432/cdss_db

# ============================================
# Python Path — uv on macOS sets UF_HIDDEN on .venv, causing Python 3.12 to skip
# editable-install .pth files. Set PYTHONPATH=src as fallback for tools other than
# uvicorn (which handles this via --app-dir src).
# ============================================
PYTHONPATH=src

# ============================================
# Application Configuration
# ============================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================
# Default LLM Selection
# ============================================
# 后续代码会读这个,决定默认调哪家
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat